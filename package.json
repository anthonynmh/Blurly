{
  "name": "blurly",
  "private": true,
  "version": "0.6.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "release:macos:app": "./scripts/with-env.sh pnpm tauri build --bundles app",
    "release:macos:dmg": "./scripts/with-env.sh ./scripts/package-macos-dmg.sh",
    "release:macos:standalone": "./scripts/with-env.sh ./scripts/package-macos-standalone.sh",
    "release:macos:validate": "./scripts/validate-macos-release.sh",
    "release:macos:validate:standalone": "./scripts/validate-macos-standalone.sh",
    "signing:dev": "./scripts/sign-dev.sh",
    "signing:check": "codesign -dvv src-tauri/target/release/bundle/macos/Blurly.app 2>&1 | grep -E '^(Authority|TeamIdentifier|Identifier|CDHash)='",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@tanstack/react-query": "^5.59.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.462.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.27.0",
    "recharts": "^2.13.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^1.7.0",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@tauri-apps/cli": "^2",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.6.3",
    "vite": "^5.4.9",
    "vitest": "^2.1.4"
  }
